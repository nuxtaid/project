{
  "name": "@nuxtaid/monorepo",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.11.0",
  "repository": {
    "type": "git",
    "url": "git@github.com:nuxtaid/project.git"
  },
  "scripts": {
    "build": "pnpm -r --filter=\"./packages/**/*\" run build",
    "boot": "f () { pnpm --filter ${1:-'*'} $2 ;}; f",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix ."
  },
  "devDependencies": {
    "@nuxt/eslint": "catalog:",
    "clsx": "catalog:",
    "eslint": "catalog:",
    "nuxt": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:"
  }
}
